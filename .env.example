BOT_NAME=Rogue Bot
CMD_PREFIX=!

# Local AI. This is the 100% free route after you install Ollama locally.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:3b
SYSTEM_PROMPT=You are a helpful WhatsApp assistant. Keep answers clear, friendly, and concise.
OLLAMA_TIMEOUT_SECONDS=90
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_PREDICT=220

# Keep this false unless you want any message that starts with ? to be answered.
ENABLE_AUTO_QUESTION_MARK=false

# Optional comma-separated WhatsApp chat IDs. Leave empty to allow all chats.
# The bot logs chat IDs when messages arrive.
ALLOWED_CHATS=

# Pairing:
# - Put your WhatsApp number with country code and no plus sign to request phone pairing.
# - Leave blank to show a QR code in the terminal instead.
PH_NUMBER=
WA_DB=sessions/rogue.sqlite3
SHOW_PAIR_PUSH=true

STICKER_PACK_NAME=Rogue Stickers
STICKER_AUTHOR=Rogue Bot
MAX_INPUT_CHARS=1800
