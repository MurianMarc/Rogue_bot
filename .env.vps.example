BOT_NAME=Rogue Bot
CMD_PREFIX=!

# VPS mode: point this at the laptop's private Tailscale IP, not a public IP.
# Example: OLLAMA_URL=http://100.90.12.34:11434
OLLAMA_URL=http://YOUR_LAPTOP_TAILSCALE_IP:11434

OLLAMA_MODEL=qwen3:8b
OLLAMA_FAST_MODEL=qwen3:1.7b
SYSTEM_PROMPT=You are Rogue Bot v3, a WhatsApp assistant with a blunt, serious, confident voice. Be useful first. Keep replies concise. You may roast bad prompts lightly, but do not use hate speech, threats, or cruelty. If the user is confused, answer directly and act like you have the room under control.
FAST_SYSTEM_PROMPT=Thou art Rogue Fast, a swift WhatsApp assistant who speaketh in a light Old English style. Keep answers short, clear, and practical. Use words like thou, thee, hath, dost, and verily sparingly so the answer remains easy to understand.
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_KEEP_ALIVE=45m
OLLAMA_NUM_PREDICT=220
OLLAMA_FAST_NUM_PREDICT=160
OLLAMA_THINK=false
OLLAMA_FAST_THINK=false
OLLAMA_NUM_THREAD=
OLLAMA_NUM_GPU=
OLLAMA_FAST_NUM_GPU=0

ENABLE_AUTO_QUESTION_MARK=false
LOW_MEMORY_MODE=true
ALLOWED_CHATS=

# Put your WhatsApp number with country code and no plus sign for phone pairing.
# Leave blank to use QR login from the VPS journal logs.
PH_NUMBER=
WA_DB=sessions/rogue.sqlite3
SHOW_PAIR_PUSH=true

STICKER_PACK_NAME=Rogue Stickers
STICKER_AUTHOR=Rogue Bot
STICKER_STORE_DIR=storage/stickers
STICKER_MAX_INPUT_MB=4
STICKER_ANIMATED_ENABLED=false
STICKER_ANIMATED_SECONDS=3
STICKER_ANIMATED_FPS=8
FILTER_DB=storage/filters.json
SCORES_TIMEOUT_SECONDS=12
SCORES_MAX_LEAGUES=4
MAX_INPUT_CHARS=1800
